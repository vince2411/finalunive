rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper: check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Helper: check if user is admin
    function isAdmin() {
      return request.auth != null && request.auth.token.email == 'admin@universitariosfc.com';
    }
    
    // Jugadores collection
    match /jugadores/{playerId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    
    // Categorías collection
    match /categorias/{categoryId} {
      allow read: if true; // Public read for landing page
      allow write: if isAdmin();
    }
    
    // Inscripciones collection
    match /inscripciones/{inscriptionId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    
    // Asistencia collection
    match /asistencia/{attendanceId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    
    // Uniformes collection
    match /uniformes/{uniformId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    
    // Facturas collection
    match /facturas/{invoiceId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    
    // Morosos collection
    match /morosos/{debtorId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    
    // Historial de pagos
    match /historial_pagos/{paymentId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    
    // Conversaciones — Row-Level Security
    // Public can read and create (for chat widget)
    // Only the conversation owner (by sessionId) or admin can update
    // Only admin can delete
    match /conversaciones/{convId} {
      allow read: if true;
      allow create: if true;
      allow update: if isAdmin()
                    || (resource.data.sessionId != null 
                        && resource.data.sessionId == request.resource.data.sessionId);
      allow delete: if isAdmin();
    }
    
    // Reportes cache
    match /reportes_cache/{reportId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    
    // Notificaciones
    match /notificaciones/{notifId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }
    
    // Configuración — tokens are sensitive, restrict read to admin
    match /configuracion/{configId} {
      // BCV rate config is public read, channel configs require admin
      allow read: if configId == 'bcv_rate' || isAdmin();
      allow write: if isAdmin();
    }
  }
}
